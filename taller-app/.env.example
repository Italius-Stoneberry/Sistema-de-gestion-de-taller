# Copiá este archivo como .env y cambiá TODOS los valores.
# NUNCA subas el .env real a ningún lado.

# --- Base de datos ---
DB_USER=taller
DB_PASSWORD=cambiar_esta_clave_larga_y_aleatoria
DB_NAME=taller

# --- Seguridad ---
# Clave para firmar las sesiones. Generá una así (en el NAS o cualquier Linux/Mac):
#   openssl rand -base64 48
JWT_SECRET=pega_aca_una_cadena_larga_y_aleatoria

# Clave para que n8n cargue datos automáticamente (ingesta IA). Generá otra con openssl rand -hex 32
INGEST_API_KEY=pega_aca_otra_cadena_larga_y_aleatoria

# --- Usuario administrador inicial (se crea solo la primera vez) ---
ADMIN_NOMBRE=Papa
ADMIN_EMAIL=admin@taller.local
ADMIN_PASSWORD=cambiar_en_el_primer_ingreso
