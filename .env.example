# Copiá este archivo como .env y cambiá TODOS los valores. NUNCA subas el .env real.

# --- Base de datos ---
DB_USER=taller
DB_PASSWORD=cambiar_esta_clave_larga_y_aleatoria
DB_NAME=taller

# --- Seguridad ---
# Generá una clave así:  openssl rand -base64 48
JWT_SECRET=pega_aca_una_cadena_larga_y_aleatoria

# Clave para la ingesta automática (n8n).  openssl rand -hex 32
INGEST_API_KEY=pega_aca_otra_cadena_larga_y_aleatoria

# Números autorizados a usar el asistente por WhatsApp (coma-separados, con código de país).
# IMPORTANTE: vacío = NO responde a NADIE (fail-safe). Cargá acá los números de la familia.
# Ej: AUTORIZADOS=5493511111111,5493512222222
AUTORIZADOS=

# --- IA local (Ollama) ---
# Cuánto queda el modelo cargado en la GPU después del último mensaje del asistente.
# 30m = balance (rápido en conversación, libera VRAM al rato). Otras opciones: 5m, 2h, 24h.
OLLAMA_KEEP_ALIVE=30m

# --- Imágenes por WhatsApp (adjuntos) ---
# La app baja las fotos desde WAHA usando su API. Poné la MISMA key que usás en WAHA.
WAHA_URL=http://host.docker.internal:3001
WAHA_API_KEY=pega_aca_la_api_key_de_waha

# --- Usuario administrador inicial (se crea solo la primera vez) ---
ADMIN_NOMBRE=Papa
ADMIN_EMAIL=admin@taller.local
ADMIN_PASSWORD=cambiar_en_el_primer_ingreso
